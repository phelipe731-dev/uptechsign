APP_ENV=production

# Dominio publico final do sistema
BASE_URL=https://assinatura.uptechbrasil.com.br

# Gere um valor longo e aleatorio antes de usar em producao
SECRET_KEY=troque-por-um-token-longo-e-aleatorio

# Ajuste ao dominio publico definitivo
CORS_ALLOWED_ORIGINS=https://assinatura.uptechbrasil.com.br
ALLOWED_HOSTS=assinatura.uptechbrasil.com.br,localhost,127.0.0.1

# So use true quando houver proxy reverso confiavel na frente
TRUST_PROXY_HEADERS=true

# Nunca deixe true em producao
DEBUG_EXPOSE_OTP=false

# Informacoes publicas do produto e contato
PUBLIC_APP_NAME=Uptech Sign
LEGAL_ENTITY_NAME=Uptech Sign Ltda
LEGAL_ADDRESS=Rua Exemplo, 123 - Sao Paulo/SP - CEP 00000-000
SUPPORT_EMAIL=suporte@uptechbrasil.com.br
SUPPORT_WHATSAPP=+55 11 99999-9999
SUPPORT_URL=https://uptechbrasil.com.br/suporte
PRIVACY_CONTACT_EMAIL=privacidade@uptechbrasil.com.br
DPA_CONTACT_EMAIL=privacidade@uptechbrasil.com.br

# SMTP real
SMTP_HOST=smtp.seu-provedor.com.br
SMTP_PORT=587
SMTP_USER=nao-responder@seudominio.com.br
SMTP_PASSWORD=troque-por-senha-real
SMTP_FROM=nao-responder@seudominio.com.br
SMTP_FROM_NAME=Uptech Sign

# Certificado institucional A1
INSTITUTIONAL_PFX_PATH=uptech-sign-a1.pfx
INSTITUTIONAL_PFX_PASSWORD=troque-por-senha-real
INSTITUTIONAL_SIGNATURE_NAME=Uptech Sign
INSTITUTIONAL_SIGNATURE_PROFILE=PAdES-B-B
